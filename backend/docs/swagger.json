{
    "swagger": "2.0",
    "info": {
        "description": "API for veterinary clinics and shifters.",
        "title": "Vet Shifter API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/auth/forgot-password": {
            "post": {
                "description": "Sends reset link to email if account exists. Always returns 202.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Request password reset",
                "parameters": [
                    {
                        "description": "Email",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.ForgotPasswordRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/login/owner": {
            "post": {
                "description": "Returns JWT for company owners. Token expiry 24h or 7d when remember_me is true.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Login as company owner",
                "parameters": [
                    {
                        "description": "Credentials",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.LoginCompanyOwnerRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.LoginCompanyOwnerResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Invalid email or password",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/login/veterinary": {
            "post": {
                "description": "Returns JWT for shift veterinaries. Token expiry 24h or 7d when remember_me is true.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Login as shift veterinary",
                "parameters": [
                    {
                        "description": "Credentials",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.LoginVeterinaryRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.LoginVeterinaryResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    },
                    "401": {
                        "description": "Invalid email or password",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/logout": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Stateless JWT: server does not invalidate. Client must clear stored token.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Logout (client should discard token)",
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/reset-password": {
            "post": {
                "description": "Consumes the token from email and sets new password. Token is invalidated.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Reset password with token",
                "parameters": [
                    {
                        "description": "Token and new password",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.ResetPasswordRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid token or weak password",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    }
                }
            }
        },
        "/auth/user-type": {
            "get": {
                "description": "Checks company_owners and shift_veterinaries by email. Returns user_type for login redirect.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Get user type by email",
                "parameters": [
                    {
                        "type": "string",
                        "description": "User email",
                        "name": "email",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "company_owner or shift_veterinary",
                        "schema": {
                            "$ref": "#/definitions/internal_auth_infrastructure_controllers.GetUserTypeResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid email",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Email not found",
                        "schema": {
                            "$ref": "#/definitions/rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse"
                        }
                    }
                }
            }
        },
        "/companies": {
            "post": {
                "description": "Creates a company and its owner account. Requires LGPD consent.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "companies"
                ],
                "summary": "Register a new company with owner",
                "parameters": [
                    {
                        "description": "Company and owner data",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_companies_infrastructure_controllers.RegisterCompanyRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created with company_id",
                        "schema": {
                            "$ref": "#/definitions/internal_companies_infrastructure_controllers.RegisterCompanyResponse"
                        }
                    },
                    "400": {
                        "description": "Invalid request body or validation error",
                        "schema": {
                            "$ref": "#/definitions/internal_companies_infrastructure_controllers.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "CNPJ or email already exists",
                        "schema": {
                            "$ref": "#/definitions/internal_companies_infrastructure_controllers.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/internal_companies_infrastructure_controllers.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "internal_auth_infrastructure_controllers.ForgotPasswordRequest": {
            "type": "object",
            "required": [
                "email"
            ],
            "properties": {
                "email": {
                    "type": "string"
                }
            }
        },
        "internal_auth_infrastructure_controllers.GetUserTypeResponse": {
            "type": "object",
            "properties": {
                "user_type": {
                    "type": "string"
                }
            }
        },
        "internal_auth_infrastructure_controllers.LoginCompanyOwnerRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "remember_me": {
                    "type": "boolean"
                }
            }
        },
        "internal_auth_infrastructure_controllers.LoginCompanyOwnerResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                }
            }
        },
        "internal_auth_infrastructure_controllers.LoginVeterinaryRequest": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "remember_me": {
                    "type": "boolean"
                }
            }
        },
        "internal_auth_infrastructure_controllers.LoginVeterinaryResponse": {
            "type": "object",
            "properties": {
                "access_token": {
                    "type": "string"
                },
                "expires_at": {
                    "type": "string"
                }
            }
        },
        "internal_auth_infrastructure_controllers.ResetPasswordRequest": {
            "type": "object",
            "required": [
                "new_password",
                "token"
            ],
            "properties": {
                "new_password": {
                    "type": "string"
                },
                "token": {
                    "type": "string"
                }
            }
        },
        "internal_companies_infrastructure_controllers.ErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                }
            }
        },
        "internal_companies_infrastructure_controllers.RegisterCompanyRequest": {
            "type": "object",
            "required": [
                "cnpj",
                "company_name",
                "consent_lgpd",
                "email",
                "owner_name",
                "password",
                "phone"
            ],
            "properties": {
                "city": {
                    "type": "string"
                },
                "cnpj": {
                    "type": "string"
                },
                "company_name": {
                    "type": "string"
                },
                "consent_lgpd": {
                    "type": "boolean"
                },
                "email": {
                    "type": "string"
                },
                "number": {
                    "type": "string"
                },
                "owner_name": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                },
                "phone": {
                    "type": "string"
                },
                "state": {
                    "type": "string"
                },
                "street": {
                    "type": "string"
                },
                "zip_code": {
                    "type": "string"
                }
            }
        },
        "internal_companies_infrastructure_controllers.RegisterCompanyResponse": {
            "type": "object",
            "properties": {
                "company_id": {
                    "type": "string"
                }
            }
        },
        "rodrigoorlandini_vet-shifter_internal__shared_api.ApiErrorResponse": {
            "type": "object",
            "properties": {
                "code": {
                    "type": "string"
                },
                "error": {
                    "type": "string"
                }
            }
        }
    }
}