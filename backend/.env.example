# Database configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vet_shifter"

# API configuration
API_PORT=8000

# Auth JWT secret
JWT_SECRET=your-secret-at-least-32-chars

# Email sender configuration
EMAIL_SENDER_BASE_URL=http://localhost:3000
EMAIL_SENDER_API_KEY=resend-api-key
EMAIL_SENDER_TEST_DESTINATION=test@example.com
EMAIL_SENDER_FROM_EMAIL="Vet Shifter <onboarding@resend.dev>"

# Password reset token validity in hours
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
